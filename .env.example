# =============================================================================
# Adversary Sim — Sophos Adversary Simulation Platform
# Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — your secrets will NOT be committed.
# =============================================================================

# ── n8n Workflow Automation ─────────────────────────────────────────────────
# Password for the n8n admin UI (required)
N8N_PASSWORD=

# ── Ollama (AI Enrichment) ─────────────────────────────────────────────────
# Model for scenario enrichment (must be pulled: ollama pull <model>)
OLLAMA_MODEL=llama3.2:3b

# ── AI Provider ────────────────────────────────────────────────────────
# Choose one: anthropic, openai, gemini, ollama
# Cloud providers need an API key. Ollama is free and runs locally.
AI_PROVIDER=

# API Key — required for anthropic, openai, gemini (not needed for ollama)
AI_API_KEY=

# Model override — leave blank for sensible defaults:
#   anthropic: claude-sonnet-4-20250514
#   openai: gpt-4o
#   gemini: gemini-2.5-flash
#   ollama: llama3.2:3b
AI_MODEL=

# ── Guacamole (Browser-Based RDP) ──────────────────────────────────────────
# Only used in standalone mode (when LabOps is not installed)
# Set these after first Guacamole login if you change the defaults
GUAC_ADMIN_USER=guacadmin
GUAC_ADMIN_PASSWORD=guacadmin

# ── Victim VM Credentials ──────────────────────────────────────────────────
# Used by console.html for RDP connections
VICTIM_USER=demo
VICTIM_PASSWORD=

# ── Optional: Port Overrides ───────────────────────────────────────────────
# Change these if defaults conflict with other services
# NGINX_PORT=8081
# N8N_PORT=5679
# CALDERA_PORT=8888
# GUAC_PORT=8085
# KALI_PORT=2222

# ── Optional: Timezone ─────────────────────────────────────────────────────
# TIMEZONE=America/Chicago
