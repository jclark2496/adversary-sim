    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nlet cfg = { provider: '', apiKey: '', model: '' };\ntry {\n  cfg = JSON.parse(fs.readFileSync('/data/scenarios/ai-config.json', 'utf-8'));\n} catch(e) {}\nconst masked = cfg.apiKey ? '••••' + cfg.apiKey.slice(-4) : '';\nreturn [{ json: { provider: cfg.provider, apiKeyMasked: masked, model: cfg.model } }];"
      },
      "id": "settings-read-config",
      "name": "Read Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-580, 0]
    },
