      "id": "settings-post-webhook",
      "name": "Webhook - POST Settings",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-800, 250],
      "webhookId": "settings-save"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst body = $input.first().json.body || $input.first().json;\nconst cfg = { provider: body.provider || '', apiKey: body.apiKey || '', model: body.model || '' };\nfs.writeFileSync('/data/scenarios/ai-config.json', JSON.stringify(cfg, null, 2));\nreturn [{ json: { success: true, provider: cfg.provider } }];"
      },
      "id": "settings-write-config",
      "name": "Write Config",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
