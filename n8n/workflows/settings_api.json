    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "settings/test",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "settings-test-webhook",
      "name": "Webhook - POST Test",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [-800, 500],
      "webhookId": "settings-test"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst provider = body.provider || '';\nconst key = body.apiKey || '';\nlet url, headers, reqBody, method = 'POST';\nswitch (provider) {\n  case 'anthropic':\n    url = 'https://api.anthropic.com/v1/messages';\n    headers = { 'x-api-key': key, 'anthropic-version': '2023-06-01', 'content-type': 'application/json' };\n    reqBody = JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 10, messages: [{ role: 'user', content: 'Hi' }] });\n    break;\n  case 'openai':\n    url = 'https://api.openai.com/v1/chat/completions';\n    headers = { 'Authorization': 'Bearer ' + key, 'Content-Type': 'application/json' };\n    reqBody = JSON.stringify({ model: 'gpt-4o', max_tokens: 10, messages: [{ role: 'user', content: 'Hi' }] });\n    break;\n  case 'gemini':\n    url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=' + key;\n    headers = { 'Content-Type': 'application/json' };\n    reqBody = JSON.stringify({ contents: [{ parts: [{ text: 'Hi' }] }] });\n    break;\n  case 'ollama':\n    url = 'http://host.docker.internal:11434/api/tags';\n    headers = {}; reqBody = ''; method = 'GET';\n    break;\n  default:\n    throw new Error('Unknown provider: ' + provider);\n}\nreturn [{ json: { url, headers, body: reqBody, method } }];"
      },
      "id": "settings-build-test",
      "name": "Build Test Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-580, 500]
    },
    {
      "parameters": {
        "method": "={{ $json.method }}",
        "url": "={{ $json.url }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": []
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ $json.body }}",
        "options": {
          "allowUnauthorizedCerts": true,
          "timeout": 15000
        }
      },
      "id": "settings-test-http",
      "name": "Test AI Call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-360, 500]
    },
    {
